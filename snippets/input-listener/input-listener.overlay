&pointing_listener {
    status = "okay";
    device = <&pointing_device>;

    input-processors = <&zip_temp_layer 1 10000>; //追記: AMLのレイヤーとタイムアウトする時間 動作確認済

    scroll_listener { //追記: スクロールレイヤー
        layers = <2>;
        input-processors = <&zip_xy_scaler 1 3>
        , <&zip_xy_to_scroll_mapper>
        , <&zip_scroll_transform INPUT_TRANSFORM_Y_INVERT>;
};
